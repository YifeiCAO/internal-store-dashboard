      "SIGNAL_TOO_LATE": "same-step leaky probe passes the absolute gate but causal prior does not",
      "REVERSE_CONTEXT_SIGNAL_INSUFFICIENT": "causal absolute or margin gate fails without a leaky-only recovery"
    },
    "training": "none",
    "model_change": "none; diagnostic replay only",
    "post_result_rule": "only REVERSE_CONTEXT_SIGNAL_CONFIRMED may unlock a zero-parameter M1g pilot on new dev episodes"
